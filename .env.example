# Wolgup Lab local environment template
# Copy to .env.local for frontend-only local overrides or .env for Docker Compose.
# Do not commit real API keys, database passwords, or personal local values.

# Kakao Maps JavaScript SDK browser key for future frontend map rendering.
# Owner: Frontend/Infra
# Consumed by: frontend browser runtime
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=

# Backend PostgreSQL JDBC connection URL.
# Owner: Backend/Infra
# Consumed by: backend Spring Boot datasource and Docker Compose
DATABASE_URL=

# Backend PostgreSQL username.
# Owner: Backend/Infra
# Consumed by: backend Spring Boot datasource and Docker Compose
DATABASE_USERNAME=

# Backend PostgreSQL password.
# Owner: Backend/Infra
# Consumed by: backend Spring Boot datasource and Docker Compose
DATABASE_PASSWORD=
